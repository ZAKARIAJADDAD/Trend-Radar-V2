# === TELEGRAM BOT CONFIG ===
# 1. Open Telegram → search @BotFather
# 2. Send /newbot → follow prompts → copy the token
TELEGRAM_BOT_TOKEN=

# 3. Open Telegram → search @userinfobot
# 4. Send /start → copy your Chat ID
TELEGRAM_CHAT_ID=

# === OPTIONAL: GOOGLE ALERTS ===
# Create alerts at https://www.google.com/alerts
# Set delivery to "RSS Feed", then paste the feed URL here
GOOGLE_ALERTS_RSS=
